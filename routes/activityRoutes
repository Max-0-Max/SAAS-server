const express = require('express');
const Project = require('../models/Project');
const User = require('../models/User');
const ActivityLog = require('../models/ActivityLog');
const authMiddleware = require('../middleware/auth');

const router = express.Router();

/* ── GET /api/activity/feed ──
   Workspace-wide activity: every logged change for anything you own
   (projects and tasks, past or present) plus anything ever assigned to you.
   Deliberately does NOT re-derive visibility by looking up currently-
   existing tasks/projects — owner_id/assignee_id are denormalized snapshots
   recorded on the log entry itself at write time, so deleting a task or
   project can never erase its own history from this feed.
   Every actor who touched something appears here regardless of their role
   (owner, admin, member, or viewer-adjacent assignee) — logActivity always
   records the real req.userId that performed the action, with no
   role-based filtering on write.
   Supports simple pagination via ?before=<ISO date>&limit=<n>. ── */
router.get('/feed', authMiddleware, async (req, res) => {
  try {
    const limit = Math.min(parseInt(req.query.limit) || 50, 100);
    const before = req.query.before ? new Date(req.query.before) : null;

    const filter = {
      $or: [{ owner_id: req.userId }, { assignee_id: req.userId }],
    };
    if (before) filter.created_at = { $lt: before };

    // Fetch one extra to know if there's more beyond this page.
    const entries = await ActivityLog.find(filter).sort({ created_at: -1 }).limit(limit + 1);
    const hasMore = entries.length > limit;
    const page = entries.slice(0, limit);

    const actorIds = [...new Set(page.map(e => String(e.actor_id)))];
    const projIds = [...new Set(page.map(e => e.project_id).filter(Boolean).map(String))];
    const [actors, projects] = await Promise.all([
      User.find({ _id: { $in: actorIds } }).select('name email'),
      Project.find({ _id: { $in: projIds } }).select('name'), // best-effort — may be a deleted project, that's fine
    ]);
    const actorMap = Object.fromEntries(actors.map(a => [String(a._id), a.name || a.email]));
    const projectMap = Object.fromEntries(projects.map(p => [String(p._id), p.name]));

    res.json({
      entries: page.map(e => ({
        id: e._id,
        entity_type: e.entity_type,
        task_id: e.task_id,
        action: e.action,
        details: e.details,
        actor_name: actorMap[String(e.actor_id)] || 'Someone',
        actor_id: e.actor_id,
        task_title: e.meta?.title || (e.entity_type === 'project' ? 'Untitled project' : 'Untitled task'),
        project_name: projectMap[String(e.project_id)] || null,
        created_at: e.created_at,
      })),
      has_more: hasMore,
    });
  } catch (err) {
    console.error('GET /activity/feed', err);
    res.status(500).json({ message: 'Server Error' });
  }
});

module.exports = router;
